    "remove-local": "graph remove --node http://localhost:8020/ graph-delegation-events",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 graph-delegation-events"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "^0.93.2",
    "@graphprotocol/graph-ts": "^0.35.1"
  }
